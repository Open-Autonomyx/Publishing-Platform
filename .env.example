# Universal Creative Platform - Environment Variables

# Database
DATABASE_URL=postgresql://dev:dev@localhost:5432/creative_platform
DB_HOST=localhost
DB_PORT=5432
DB_USER=dev
DB_PASSWORD=dev
DB_NAME=creative_platform

# API Server
API_PORT=3001
API_HOST=0.0.0.0
API_ENV=development
API_LOG_LEVEL=info

# JWT / Auth
JWT_SECRET=your-super-secret-jwt-key-here-change-in-prod
JWT_EXPIRY=24h
API_KEY_LENGTH=32

# Services
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# Agent Configuration
AGENT_SDK_ENDPOINT=http://localhost:3000
AGENT_TIMEOUT=300s
AGENT_RETRY_COUNT=3

# Monitoring
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_URL=http://localhost:3100

# External Services (configure as needed)
SLACK_WEBHOOK_URL=
GITHUB_TOKEN=
AZURE_STORAGE_CONNECTION_STRING=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Feature Flags
FEATURE_APPROVAL_WORKFLOW=true
FEATURE_AGENT_PUBLISHING=true
FEATURE_MULTI_TENANT=true

# Email (if needed)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate Limiting
RATE_LIMIT_REQUESTS_PER_SECOND=100
RATE_LIMIT_BURST_SIZE=200
